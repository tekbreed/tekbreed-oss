{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["build/**", "dist/**", ".vitepress/dist/**"]
		},
		"build:watch": {
			"cache": false,
			"persistent": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"//#format-and-lint": {
			"inputs": ["$TURBO_DEFAULT$"],
			"outputs": []
		},
		"//#format-and-lint:fix": {
			"cache": false,
			"inputs": ["$TURBO_DEFAULT$"],
			"outputs": []
		},
		"//#format-and-lint:fix:unsafe": {
			"cache": false,
			"inputs": ["$TURBO_DEFAULT$"],
			"outputs": []
		},
		"test:run": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"test:watch": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},
		"test:coverage": {
			"dependsOn": ["^build"],
			"outputs": ["coverage/**"]
		},
		"lint:package": {
			"dependsOn": ["build"],
			"outputs": []
		},
		"benchmark:smoke": {
			"dependsOn": ["^build"],
			"outputs": ["../benchmark-results/smoke/**"]
		},
		"benchmark:release": {
			"dependsOn": ["^build"],
			"outputs": ["../benchmark-results/release/**"]
		},
		"benchmark:full": {
			"dependsOn": ["^build"],
			"cache": false,
			"outputs": ["../benchmark-results/full/**"]
		},
		"benchmark:compare": {
			"dependsOn": ["benchmark:release"],
			"outputs": []
		}
	}
}
