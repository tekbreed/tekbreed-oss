{
	"name": "@tekbreed/tekmemo-benchmarks",
	"private": true,
	"type": "module",
	"scripts": {
		"smoke": "node --import tsx scripts/run-smoke.ts",
		"release": "node --import tsx scripts/run-release.ts",
		"full": "node --import tsx scripts/run-full.ts",
		"benchmark:smoke": "pnpm smoke",
		"benchmark:release": "pnpm release",
		"benchmark:full": "pnpm full",
		"benchmark:compare": "node --import tsx scripts/compare-baseline.ts",
		"report": "node --import tsx scripts/generate-report.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@tekbreed/tekmemo-benchmark-kit": "workspace:*",
		"@tekbreed/tekmemo-fs": "workspace:*",
		"@tekbreed/tekmemo-recall": "workspace:*",
		"@tekbreed/tekmemo-rerank": "workspace:*",
		"@tekbreed/tekmemo": "workspace:*"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"tsx": "^4.21.0",
		"typescript": "5.9.2"
	}
}
