{
	"name": "@tekmemo/ai-sdk",
	"version": "0.2.1",
	"description": "Vercel AI SDK integration for TekMemo local, cloud, and hybrid memory runtimes.",
	"private": false,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/tekmemo.git",
		"directory": "packages/ai-sdk"
	},
	"homepage": "https://docs.memo.tekbreed.com/packages/ai-sdk",
	"bugs": {
		"url": "https://github.com/tekbreed/tekmemo/issues"
	},
	"type": "module",
	"sideEffects": false,
	"keywords": [
		"agents",
		"ai",
		"chatbot",
		"cloud",
		"hybrid",
		"llm",
		"mcp",
		"memory",
		"recall",
		"scoped-memory",
		"tekmemo",
		"typescript"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"lint:package": "publint",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"dependencies": {
		"tekmemo": "workspace:^",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@repo/test-utils": "workspace:*",
		"@repo/tsdown-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/utils": "workspace:*",
		"ai": "^6.0.197"
	},
	"peerDependencies": {
		"ai": ">=5.0.0 <7.0.0",
		"@tekmemo/cloud-client": ">=0.1.1"
	},
	"peerDependenciesMeta": {
		"@tekmemo/cloud-client": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=22"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	}
}
