{
	"name": "@tekbreed/tekmemo",
	"version": "1.0.0-alpha.0",
	"private": false,
	"description": "TekMemo memory runtime for AI apps and agents",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/tekbreed-oss.git",
		"directory": "packages/tekmemo"
	},
	"homepage": "https://oss.tekbreed.com/tekmemo",
	"bugs": {
		"url": "https://github.com/tekbreed/tekbreed-oss/issues"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"agents",
		"ai",
		"llm",
		"memory",
		"recall",
		"@tekbreed/tekmemo",
		"typescript"
	],
	"devDependencies": {
		"@repo/test-utils": "workspace:*",
		"@repo/tsdown-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/utils": "workspace:*",
		"ai": "^6.0.174",
		"openai": "^6.10.0"
	},
	"engines": {
		"node": ">=22"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	},
	"dependencies": {
		"zod": "^4.4.2"
	},
	"peerDependencies": {
		"@modelcontextprotocol/sdk": ">=1.29.0",
		"@upstash/vector": ">=1.2.0",
		"ai": ">=5.0.0 <7.0.0",
		"openai": "^6.10.0"
	},
	"peerDependenciesMeta": {
		"@modelcontextprotocol/sdk": {
			"optional": true
		},
		"@upstash/vector": {
			"optional": true
		},
		"ai": {
			"optional": true
		},
		"openai": {
			"optional": true
		}
	}
}
