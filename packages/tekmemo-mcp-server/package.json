{
	"name": "@tekbreed/tekmemo-mcp-server",
	"version": "1.0.0-alpha.0",
	"private": false,
	"description": "TekMemo MCP Server package.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/tekbreed-oss.git",
		"directory": "packages/tekmemo-mcp-server"
	},
	"homepage": "https://oss.tekbreed.com/tekmemo-mcp-server",
	"bugs": {
		"url": "https://github.com/tekbreed/tekbreed-oss/issues"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"bin": {
		"tekmemo-mcp": "./dist/bin/tekmemo-mcp.mjs"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"ai",
		"agents",
		"memory",
		"tekmemo",
		"typescript"
	],
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": ">=1.29.0",
		"@tekbreed/tekmemo": "workspace:^"
	},
	"devDependencies": {
		"@repo/test-utils": "workspace:*",
		"@repo/tsdown-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/utils": "workspace:*",
		"@types/node": "^25.9.2"
	},
	"engines": {
		"node": ">=22"
	}
}
