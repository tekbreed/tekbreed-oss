{
	"name": "@tekmemo/graph",
	"version": "0.1.0",
	"description": "Provider-neutral graph memory primitives for TekMemo.",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"test": "vitest",
		"test:run": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint:package": "publint"
	},
	"keywords": [
		"tekmemo",
		"memory",
		"graph",
		"agents",
		"ai"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/tekmemo.git",
		"directory": "packages/graph"
	},
	"homepage": "https://github.com/tekbreed/tekmemo/tree/main/packages/graph#readme",
	"bugs": {
		"url": "https://github.com/tekbreed/tekmemo/issues"
	},
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@repo/test-utils": "workspace:*",
		"@repo/tsdown-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/utils": "workspace:*"
	}
}
