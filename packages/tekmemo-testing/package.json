{
	"name": "@tekbreed/tekmemo-testing",
	"version": "1.0.0-alpha.0",
	"private": false,
	"license": "MIT",
	"description": "Shared contract tests, fixtures, and fakes for TekMemo packages.",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./contracts": {
			"import": {
				"types": "./dist/contracts/index.d.mts",
				"default": "./dist/contracts/index.mjs"
			},
			"require": {
				"types": "./dist/contracts/index.d.cts",
				"default": "./dist/contracts/index.cjs"
			}
		},
		"./fakes": {
			"import": {
				"types": "./dist/fakes/index.d.mts",
				"default": "./dist/fakes/index.mjs"
			},
			"require": {
				"types": "./dist/fakes/index.d.cts",
				"default": "./dist/fakes/index.cjs"
			}
		},
		"./fixtures": {
			"import": {
				"types": "./dist/fixtures/index.d.mts",
				"default": "./dist/fixtures/index.mjs"
			},
			"require": {
				"types": "./dist/fixtures/index.d.cts",
				"default": "./dist/fixtures/index.cjs"
			}
		},
		"./vitest": {
			"import": {
				"types": "./dist/vitest.d.mts",
				"default": "./dist/vitest.mjs"
			},
			"require": {
				"types": "./dist/vitest.d.cts",
				"default": "./dist/vitest.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint:package": "publint",
		"clean": "rm -rf dist coverage"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"peerDependencies": {
		"@tekbreed/tekmemo": "workspace:^",
		"vitest": "^4.1.5"
	},
	"devDependencies": {
		"@repo/tsdown": "workspace:*",
		"@repo/typescript": "workspace:*",
		"@tekbreed/tekmemo": "workspace:^"
	}
}
