{
	"name": "@tekmemo/agentfs",
	"version": "0.1.0",
	"description": "AgentFS-backed MemoryStore adapter for TekMemo with sync and lease management.",
	"private": false,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/tekmemo.git",
		"directory": "packages/agentfs"
	},
	"homepage": "https://github.com/tekbreed/tekmemo#readme",
	"bugs": {
		"url": "https://github.com/tekbreed/tekmemo/issues"
	},
	"type": "module",
	"sideEffects": false,
	"keywords": [
		"ai",
		"memory",
		"agents",
		"llm",
		"recall",
		"typescript",
		"tekmemo"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"lint:package": "publint"
	},
	"dependencies": {
		"tekmemo": "workspace:^"
	},
	"devDependencies": {
		"@repo/test-utils": "workspace:*",
		"@repo/tsdown-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/utils": "workspace:*"
	}
}
