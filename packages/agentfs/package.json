{
	"name": "@tekbreed/tekmemo-agentfs",
	"version": "0.2.0",
	"description": "AgentFS session workspace and MemoryStore adapter for TekMemo-powered agents.",
	"private": false,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/oss.git",
		"directory": "packages/agentfs"
	},
	"homepage": "https://oss.tekbreed.com/tekmemo/packages/agentfs",
	"bugs": {
		"url": "https://github.com/tekbreed/oss/issues"
	},
	"type": "module",
	"sideEffects": false,
	"keywords": [
		"ai",
		"memory",
		"agents",
		"llm",
		"recall",
		"typescript",
		"@tekbreed/tekmemo"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"dependencies": {
		"@tekbreed/tekmemo": "workspace:^"
	},
	"devDependencies": {
		"@repo/test-utils": "workspace:*",
		"@repo/tsdown-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/utils": "workspace:*"
	}
}
