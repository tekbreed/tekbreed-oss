{
	"name": "@tekmemo/server",
	"version": "0.1.0",
	"description": "Hono-based self-hostable TekMemo memory server for Node.js, Docker, and Cloudflare Workers.",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./node": {
			"import": {
				"types": "./dist/node/index.d.mts",
				"default": "./dist/node/index.mjs"
			},
			"require": {
				"types": "./dist/node/index.d.cts",
				"default": "./dist/node/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"agents",
		"ai",
		"hono",
		"memory",
		"self-host",
		"server",
		"tekmemo"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/tekmemo.git",
		"directory": "packages/server"
	},
	"bugs": {
		"url": "https://github.com/tekbreed/tekmemo/issues"
	},
	"homepage": "https://docs.memo.tekbreed.com/packages/server",
	"dependencies": {
		"hono": "^4.12.22",
		"@aws-sdk/client-s3": "^3.1053.0",
		"@aws-sdk/s3-request-presigner": "^3.1053.0",
		"pg": "^8.21.0"
	},
	"devDependencies": {
		"@repo/tsdown-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@tekmemo/cloud-client": "workspace:*",
		"@vitest/coverage-v8": "^4.1.7",
		"typescript": "6.0.3",
		"vitest": "^4.1.7",
		"@types/pg": "^8.15.6"
	},
	"private": false,
	"engines": {
		"node": ">=22"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	}
}
