{
	"name": "@tekbreed/tekmemo-adapter-upstash",
	"version": "1.0.0-alpha.0",
	"private": false,
	"license": "MIT",
	"description": "Upstash Vector Recall Store adapter for TekMemo.",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"clean": "rm -rf dist coverage .turbo"
	},
	"dependencies": {
		"@repo/utils": "workspace:*",
		"@tekbreed/tekmemo": "workspace:^",
		"@upstash/vector": "^1.2.0"
	},
	"devDependencies": {
		"@repo/tsdown": "workspace:*",
		"@repo/typescript": "workspace:*",
		"@tekbreed/tekmemo-testing": "workspace:^",
		"@types/node": "^25.9.2"
	}
}
