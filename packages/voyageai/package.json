{
	"name": "@tekbreed/tekmemo-voyageai",
	"version": "0.2.0",
	"description": "Production-ready Voyage AI embedding adapter for TekMemo.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/oss.git",
		"directory": "packages/voyageai"
	},
	"homepage": "https://oss.tekbreed.com/tekmemo/packages/voyageai",
	"bugs": {
		"url": "https://github.com/tekbreed/oss/issues"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./testing": {
			"import": {
				"types": "./dist/testing/index.d.mts",
				"default": "./dist/testing/index.mjs"
			},
			"require": {
				"types": "./dist/testing/index.d.cts",
				"default": "./dist/testing/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"agents",
		"ai",
		"embeddings",
		"llm",
		"memory",
		"recall",
		"@tekbreed/tekmemo",
		"typescript",
		"voyage"
	],
	"devDependencies": {
		"@repo/test-utils": "workspace:*",
		"@repo/tsdown-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/utils": "workspace:*"
	},
	"private": false,
	"engines": {
		"node": ">=22"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	}
}
