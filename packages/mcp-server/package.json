{
	"name": "@tekmemo/mcp-server",
	"version": "0.1.0",
	"description": "Production-ready Model Context Protocol boundary adapter for local, cloud, and hybrid TekMemo runtimes.",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./stdio": {
			"import": {
				"types": "./dist/stdio/index.d.mts",
				"default": "./dist/stdio/index.mjs"
			},
			"require": {
				"types": "./dist/stdio/index.d.cts",
				"default": "./dist/stdio/index.cjs"
			}
		},
		"./sdk": {
			"import": {
				"types": "./dist/sdk/index.d.mts",
				"default": "./dist/sdk/index.mjs"
			},
			"require": {
				"types": "./dist/sdk/index.d.cts",
				"default": "./dist/sdk/index.cjs"
			}
		},
		"./runtime/local": {
			"import": {
				"types": "./dist/runtime/local.d.mts",
				"default": "./dist/runtime/local.mjs"
			},
			"require": {
				"types": "./dist/runtime/local.d.cts",
				"default": "./dist/runtime/local.cjs"
			}
		},
		"./runtime/cloud": {
			"import": {
				"types": "./dist/runtime/cloud.d.mts",
				"default": "./dist/runtime/cloud.mjs"
			},
			"require": {
				"types": "./dist/runtime/cloud.d.cts",
				"default": "./dist/runtime/cloud.cjs"
			}
		},
		"./runtime/hybrid": {
			"import": {
				"types": "./dist/runtime/hybrid.d.mts",
				"default": "./dist/runtime/hybrid.mjs"
			},
			"require": {
				"types": "./dist/runtime/hybrid.d.cts",
				"default": "./dist/runtime/hybrid.cjs"
			}
		},
		"./runtime/factory": {
			"import": {
				"types": "./dist/runtime/factory.d.mts",
				"default": "./dist/runtime/factory.mjs"
			},
			"require": {
				"types": "./dist/runtime/factory.d.cts",
				"default": "./dist/runtime/factory.cjs"
			}
		}
	},
	"bin": {
		"tekmemo-mcp": "./dist/bin/tekmemo-mcp.mjs"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint:package": "publint",
		"clean": "rm -rf dist coverage .turbo",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"agents",
		"ai",
		"claude-code",
		"codex",
		"mcp",
		"memory",
		"model-context-protocol",
		"tekmemo",
		"typescript"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/tekmemo.git",
		"directory": "packages/mcp"
	},
	"bugs": {
		"url": "https://github.com/tekbreed/tekmemo/issues"
	},
	"homepage": "https://docs.tekmemo.dev/packages/mcp",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"peerDependencies": {
		"@modelcontextprotocol/sdk": ">=1.29.0"
	},
	"peerDependenciesMeta": {
		"@modelcontextprotocol/sdk": {
			"optional": true
		}
	},
	"devDependencies": {
		"@repo/test-utils": "workspace:*",
		"@repo/tsdown-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@repo/utils": "workspace:*"
	},
	"dependencies": {
		"@tekmemo/agentfs": "workspace:^",
		"@tekmemo/cloud-client": "workspace:^",
		"@tekmemo/fs": "workspace:^",
		"tekmemo": "workspace:^"
	},
	"private": false,
	"engines": {
		"node": ">=22"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	}
}
