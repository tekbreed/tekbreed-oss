		"@types/node": "^22.15.3",
		"@vitest/coverage-v8": "^4.1.5",
		"dotenv": "^17.4.2",
		"publint": "^0.3.18",
		"tsdown": "^0.21.10",
		"turbo": "^2.9.7",
		"typescript": "5.9.2",
		"vitest": "^4.1.5",
		"zod": "^4.4.2"
	},
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": ">=22"
	}
