{
	"name": "@tekmemo/repo",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/tekmemo.git"
	},
	"scripts": {
		"build": "turbo run build",
		"build:watch": "turbo run build:watch",
		"check": "biome check packages apps",
		"format-and-lint": "biome check .",
		"format-and-lint:fix": "biome check . --write",
		"format-and-lint:fix:unsafe": "biome check . --write --unsafe",
		"typecheck": "turbo run typecheck --filter=./packages/* --filter=./apps/*",
		"test": "turbo run test:run",
		"test:watch": "turbo run test:watch",
		"test:coverage": "turbo run test:coverage",
		"lint:package": "turbo run lint:package",
		"benchmark:smoke": "turbo run benchmark:smoke --filter=@tekmemo/benchmarks",
		"benchmark:release": "turbo run benchmark:release --filter=@tekmemo/benchmarks",
		"benchmark:full": "turbo run benchmark:full --filter=@tekmemo/benchmarks",
		"benchmark:compare": "turbo run benchmark:compare --filter=@tekmemo/benchmarks",
		"release:check": "pnpm run ci",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"ci": "pnpm check && pnpm typecheck && pnpm test && pnpm build && pnpm lint:package && pnpm docs:build",
		"docs:dev": "pnpm --filter @tekmemo/docs dev",
		"docs:build": "pnpm --filter @tekmemo/docs build",
		"docs:preview": "pnpm --filter @tekmemo/docs preview",
		"examples:check": "node examples/scripts/check-examples.mjs && turbo run typecheck --filter=./examples/*",
		"packages:build": "turbo run build --filter=./packages/*",
		"packages:test": "turbo run test:run --filter=./packages/*",
		"release:dry-run": "changeset publish --dry-run",
		"validate:workspace": "pnpm check && pnpm typecheck && pnpm test && pnpm build && pnpm lint:package && pnpm docs:build",
		"validate:packages": "pnpm lint:package && pnpm packages:build",
		"validate:docs": "pnpm docs:check && pnpm docs:build",
		"validate:examples": "pnpm examples:check",
		"validate:release": "pnpm validate:workspace && pnpm release:dry-run",
		"docs:check": "pnpm --filter @tekmemo/docs check",
		"examples:lint": "node examples/scripts/check-examples.mjs",
		"pack:dry-run": "turbo run pack:dry-run --filter=./packages/*",
		"release:package-check": "turbo run release:check --filter=./packages/*",
		"release:preflight": "pnpm validate:workspace && pnpm release:package-check && pnpm release:dry-run",
		"publish:docs": "pnpm docs:build",
		"validate:publish": "pnpm release:preflight",
		"selfhost:node:build": "pnpm --filter @tekmemo/server build && pnpm --filter @tekmemo/self-host-node build",
		"selfhost:node:typecheck": "pnpm --filter @tekmemo/server typecheck && pnpm --filter @tekmemo/self-host-node typecheck",
		"selfhost:docker:doctor": "pnpm --filter @tekmemo/self-host-docker doctor",
		"validate:selfhost": "pnpm selfhost:node:typecheck && pnpm selfhost:node:build && pnpm --filter @tekmemo/self-host-docker typecheck && pnpm --filter @tekmemo/self-host-cloudflare typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.31.0",
		"@types/node": "^22.15.3",
		"@vitest/coverage-v8": "^4.1.5",
		"dotenv": "^17.4.2",
		"publint": "^0.3.18",
		"tsdown": "^0.21.10",
		"tsx": "^4.21.0",
		"turbo": "^2.9.7",
		"typescript": "5.9.2",
		"vitest": "^4.1.5",
		"zod": "^4.4.2"
	},
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": ">=22",
		"pnpm": ">=9.0.0"
	},
	"description": "Open-source TekMemo packages, examples, benchmarks, and developer documentation.",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/tekbreed/tekmemo/issues"
	},
	"homepage": "https://docs.memo.tekbreed.com/",
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	}
}
