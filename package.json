{
	"name": "@tekmemo/repo",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/tekmemo/tekmemo.git"
	},
	"scripts": {
		"build": "turbo run build",
		"build:watch": "turbo run build:watch",
		"check": "pnpm format-and-lint",
		"format-and-lint": "biome check .",
		"format-and-lint:fix": "biome check . --write",
		"format-and-lint:fix:unsafe": "biome check . --write --unsafe",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test:run",
		"test:watch": "turbo run test:watch",
		"test:coverage": "turbo run test:coverage",
		"lint:package": "turbo run lint:package",
		"benchmark:smoke": "turbo run benchmark:smoke --filter=@tekmemo/benchmarks",
		"benchmark:release": "turbo run benchmark:release --filter=@tekmemo/benchmarks",
		"benchmark:full": "turbo run benchmark:full --filter=@tekmemo/benchmarks",
		"benchmark:compare": "turbo run benchmark:compare --filter=@tekmemo/benchmarks",
		"release:check": "pnpm check && pnpm typecheck && pnpm test && pnpm build && pnpm lint:package",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"ci": "pnpm check && pnpm typecheck && pnpm test && pnpm build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.31.0",
		"@types/node": "^22.15.3",
		"@vitest/coverage-v8": "^4.1.5",
		"dotenv": "^17.4.2",
		"publint": "^0.3.18",
		"tsdown": "^0.21.10",
		"tsx": "^4.21.0",
		"turbo": "^2.9.7",
		"typescript": "5.9.2",
		"vitest": "^4.1.5",
		"zod": "^4.4.2"
	},
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": ">=22",
		"pnpm": ">=9"
	}
}
