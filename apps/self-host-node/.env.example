PORT=8787
TEKMEMO_API_KEY=tk_selfhost_change_me
TEKMEMO_DEFAULT_PROJECT_ID=default

# Required for Node/Docker/Railway/Fly deployment.
TEKMEMO_DATABASE_URL=postgres://tekmemo:tekmemo@localhost:5432/tekmemo

# Docker/Railway/Fly default queue. Uses the same Postgres database.
TEKMEMO_QUEUE=postgres

# Use `local` only for development. Use `s3` for production Node deployments.
TEKMEMO_OBJECT_STORE=s3
TEKMEMO_LOCAL_OBJECT_ROOT=.tekmemo/objects

# S3-compatible object storage: MinIO, AWS S3, Cloudflare R2 via S3 API,
# DigitalOcean Spaces, Backblaze B2, etc.
TEKMEMO_S3_ENDPOINT=http://localhost:9000
TEKMEMO_S3_BUCKET=tekmemo
TEKMEMO_S3_ACCESS_KEY_ID=tekmemo
TEKMEMO_S3_SECRET_ACCESS_KEY=tekmemo-secret
TEKMEMO_S3_REGION=auto
TEKMEMO_S3_FORCE_PATH_STYLE=true

TEKMEMO_DISABLE_TELEMETRY=true
TEKMEMO_DISABLE_EXTERNAL_PROVIDERS=true
