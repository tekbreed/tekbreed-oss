{
	"include": [
		"**/*",
		"**/.server/**/*",
		"**/.client/**/*",
		".react-router/types/**/*"
	],
	"exclude": [
		"Initial design",
		// Dead Node-era scaffolding that references packages not installed in
		// this Worker app (`pino`, `@t3-oss/env-core`, `next-themes`, `msw`,
		// `remix-utils`, etc.) and is not imported by any live route, loader,
		// or the Worker entry. `src/root.tsx` documents these as "deferred
		// dashboard polish wired to a Node-style `process.env` module that
		// does not exist on the Worker." Excluded — not deleted — so they can
		// be ported Worker-safe during dashboard work (P1.5+) or removed once
		// their patterns are no longer useful as reference. None are reached
		// by `~/` imports today.
		"src/utils/env.server.ts",
		"src/utils/logger.server.ts",
		"src/utils/csrf.server.ts",
		"src/utils/toast.server.ts",
		"src/utils/honeypot.server.ts",
		"src/utils/misc.ts",
		"src/utils/theme.server.ts",
		"src/components/ui/sonner.tsx",
		"src/hooks/use-is-pending.ts",
		"src/hooks/use-toast.ts",
		"tests/mocks/index.ts"
	],
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["node", "vite/client"],
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"rootDirs": [".", "./.react-router/types"],
		"paths": {
			"~/*": ["./src/*"]
		},
		"esModuleInterop": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true
	}
}
